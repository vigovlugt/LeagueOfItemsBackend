{
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Microsoft.Hosting.Lifetime": "Information"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "Seq",
                "Args": {
                    "path": "http://localhost:5341"
                }
            }
        ],
        "Enrich": ["FromLogContext"]
    },
    "Github": {
        "Owner": "vigovlugt",
        "Repository": "LeagueOfItemsFrontend",
        "Path": "data",
        "FileName": "dataset.json"
    },
    "Ugg": {
        "ApiUrl": "https://stats2.u.gg/",
        "PatchUpdateUrl": "https://static.bigbrain.gg/assets/lol/riot_patch_update/prod/ugg/ugg-api-versions.json",
        "RequestDelayMs": "1250",
        "ForbiddenRetryDelaySeconds": "60"
    },
    "Riot": {
        "ApiUrl": "https://ddragon.leagueoflegends.com/",
        "PatchScheduleUrl": "https://psedge-production.pp.sgp.pvp.net/api/v1/articles/league-of-legends/gameplay/patch-schedule-league-of-legends?locale=en-us",
        "PatchNotesUrl": "https://www.leagueoflegends.com/en-us/news/game-updates/league-of-legends-patch-{}-notes/"
    },
    "Cloudflare": {
        "AccountId": "",
        "AnalyticsApiToken": "",
        "PageViewsDataset": "pageviews",
        "PageViewsLookbackDays": "7"
    }
}
